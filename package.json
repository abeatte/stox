{
  "name": "stox",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "tsc -p tsconfig.server.json && node dist/server/index.js",
    "dev:all": "tsc -p tsconfig.server.json && concurrently -n server,vite -c blue,green \"node dist/server/index.js\" \"vite\"",
    "build": "tsc -b && vite build",
    "predeploy": "npm run lint && npm run test && npm run build",
    "deploy": "gh-pages -d dist -s \"{**,!server/**,!.kiro/**,!.notes/**}\"",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest --run",
    "kill-server": "lsof -ti :3001 | xargs kill -15 2>/dev/null; sleep 2; lsof -ti :3001 | xargs kill -9 2>/dev/null; lsof -ti :5173 | xargs kill -15 2>/dev/null; sleep 1; lsof -ti :5173 | xargs kill -9 2>/dev/null; pkill -f 'puppeteer.*Google Chrome for Testing' 2>/dev/null; echo 'Server, Vite, and Puppeteer processes cleared'",
    "invalidate-cache": "rm -f server/.stock-cache.json && echo 'Stock cache invalidated'",
    "restart-server": "npm run kill-server && npm run dev:all"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.91.0",
    "express": "^5.2.1",
    "puppeteer": "^24.39.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "fast-check": "^4.6.0",
    "gh-pages": "^6.3.0",
    "globals": "^15.11.0",
    "jsdom": "^24.1.3",
    "tsx": "^4.21.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.9"
  }
}
